# Files and directories to exclude from Docker build context

# Node modules and pnpm store
node_modules
.pnp
.pnp.js
.pnpm-debug.log*
.pnpm-store

# Build outputs and caches
.next
/out
/build
dist

# Local env and secrets
.env
.env.*
.env.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS / Editor
.DS_Store
.vscode
.idea

# Git and CI
.git
.gitignore
.gitlab-ci.yml
.github

# Testing artifacts
coverage
/test-results/
/playwright-report/
/playwright/.cache/

# Vercel / deployment
.vercel

# Prisma migrations (if you want them in the image, remove this line)
# prisma/migrations

# Optional: ignore tests and local tooling
/tests
/tests/**

# Keep package manifests and lockfile so the image can install dependencies
!package.json
!pnpm-lock.yaml

# Keep source, prisma schema, public and next config for the build
!src
!prisma
!public
!next.config.js
